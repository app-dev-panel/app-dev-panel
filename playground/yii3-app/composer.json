{
    "name": "yiisoft/app",
    "type": "project",
    "minimum-stability": "dev",
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@php ./yii serve -p 8101"
        ]
    },
    "require": {
        "php": "^8.2",
        "app-dev-panel/adapter-yii3": "*",
        "app-dev-panel/api": "*",
        "httpsoft/http-message": "^1.1.6",
        "psr/container": "^2",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1",
        "psr/log": "^3",
        "symfony/console": "^7.4.0",
        "yiisoft/aliases": "^3.1.1",
        "yiisoft/assets": "^5.1.2",
        "yiisoft/config": "^1.6.2",
        "yiisoft/csrf": "^2.2.3",
        "yiisoft/data-response": "^2.2.0",
        "yiisoft/db": "^2.0.1",
        "yiisoft/db-sqlite": "^2.0",
        "yiisoft/definitions": "^3.4.1",
        "yiisoft/di": "^1.4.1",
        "yiisoft/error-handler": "^4.3.2",
        "yiisoft/html": "^3.13",
        "yiisoft/http": "^1.3",
        "yiisoft/input-http": "^1.0.1",
        "yiisoft/log": "^2.2.1",
        "yiisoft/log-target-file": "^3.1",
        "yiisoft/middleware-dispatcher": "^5.4",
        "yiisoft/request-provider": "^1.3",
        "yiisoft/router": "^4.0.2",
        "yiisoft/router-fastroute": "^4.0.3",
        "yiisoft/session": "^3.0.1",
        "yiisoft/view": "^12.2.4",
        "yiisoft/yii-console": "^2.4.2",
        "yiisoft/yii-http": "^1.1.1",
        "yiisoft/yii-runner-console": "^2.2.1",
        "yiisoft/yii-runner-http": "^3.2.1",
        "yiisoft/yii-view-renderer": "^7.4.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpunit/phpunit": "^11.5.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../libs/Adapter/*"
        },
        {
            "type": "path",
            "url": "../../libs/API"
        },
        {
            "type": "path",
            "url": "../../libs/Kernel"
        },
        {
            "type": "path",
            "url": "../../libs/Cli"
        },
        {
            "type": "path",
            "url": "../../libs/McpServer"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests"
        }
    },
    "extra": {
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true,
        "bump-after-update": true,
        "allow-plugins": {
            "yiisoft/config": true,
            "infection/extension-installer": true,
            "codeception/c3": true,
            "composer/installers": true
        }
    }
}
