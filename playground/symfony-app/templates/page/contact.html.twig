{% extends 'base.html.twig' %}

{% block title %}Contact — ADP Symfony Playground{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Contact</h1>
    </div>

    <div class="card">
        {% if success %}
            <div class="alert alert-success">Thank you! Your message has been sent.</div>
        {% endif %}

        <form method="POST" action="{{ path('contact') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('contact') }}">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" class="form-control{{ errors.name is defined ? ' error' : '' }}" value="{{ data.name | default('') }}">
                {% if errors.name is defined %}
                    <div class="form-error">{{ errors.name }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" class="form-control{{ errors.email is defined ? ' error' : '' }}" value="{{ data.email | default('') }}">
                {% if errors.email is defined %}
                    <div class="form-error">{{ errors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" class="form-control{{ errors.message is defined ? ' error' : '' }}">{{ data.message | default('') }}</textarea>
                {% if errors.message is defined %}
                    <div class="form-error">{{ errors.message }}</div>
                {% endif %}
            </div>

            <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
    </div>
{% endblock %}
