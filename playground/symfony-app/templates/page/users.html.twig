{% extends 'base.html.twig' %}

{% block title %}Users — ADP Symfony Playground{% endblock %}

{% block body %}
    <div class="page-header">
        <h1>Users</h1>
    </div>

    <div class="card">
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.name }}</td>
                            <td>{{ user.email }}</td>
                            <td><span class="badge" style="background: var(--color-badge-bg); color: var(--color-badge-text);">{{ user.role }}</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
