{
    "name": "app-dev-panel/playground-laravel",
    "type": "project",
    "description": "Laravel playground for ADP",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "app-dev-panel/adapter-laravel": "*",
        "app-dev-panel/testing": "*",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "nyholm/psr7": "^1.8",
        "open-telemetry/exporter-otlp": "^1.2",
        "open-telemetry/sdk": "^1.13",
        "zircote/swagger-php": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "laravel/tinker": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "repositories": [
        {"type": "path", "url": "../../libs/Kernel"},
        {"type": "path", "url": "../../libs/API"},
        {"type": "path", "url": "../../libs/Cli"},
        {"type": "path", "url": "../../libs/Testing"},
        {"type": "path", "url": "../../libs/Adapter/Laravel"},
        {"type": "path", "url": "../../libs/McpServer"}
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "adp-ensure-dirs": [
            "@php -r \"foreach (['storage/framework/views','storage/framework/cache','storage/framework/cache/data','storage/framework/sessions','bootstrap/cache'] as \\$d) { if (!is_dir(\\$d)) { mkdir(\\$d, 0755, true); } }\"",
            "@php -r \"if (!file_exists('database/database.sqlite')) { @mkdir('database', 0755, true); touch('database/database.sqlite'); }\""
        ],
        "post-install-cmd": [
            "@adp-ensure-dirs"
        ],
        "post-autoload-dump": [
            "@adp-ensure-dirs",
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi || true",
            "@php artisan vendor:publish --tag=app-dev-panel-assets --force --ansi || true"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "bash ../../bin/serve.sh 8104"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
