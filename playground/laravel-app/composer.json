{
    "name": "app-dev-panel/playground-laravel",
    "type": "project",
    "description": "Laravel playground for ADP",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "app-dev-panel/adapter-laravel": "*",
        "app-dev-panel/testing": "*",
        "guzzlehttp/guzzle": "^7.5",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "laravel/tinker": "^2.0"
    },
    "repositories": [
        {"type": "path", "url": "../../libs/Kernel"},
        {"type": "path", "url": "../../libs/API"},
        {"type": "path", "url": "../../libs/Cli"},
        {"type": "path", "url": "../../libs/Testing"},
        {"type": "path", "url": "../../libs/Adapter/Laravel"},
        {"type": "path", "url": "../../libs/McpServer"}
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "bash ../../bin/serve.sh 8104"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
