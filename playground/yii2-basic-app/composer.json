{
    "name": "app-dev-panel/yii2-playground",
    "type": "project",
    "description": "Yii 2 playground app demonstrating ADP integration",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "app-dev-panel/adapter-yii2": "*",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "yiisoft/yii2": "^2.0.50",
        "yiisoft/yii2-symfonymailer": "^4.0",
        "zircote/swagger-php": "^4.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../libs/Adapter/Yii2"
        },
        {
            "type": "path",
            "url": "../../libs/API"
        },
        {
            "type": "path",
            "url": "../../libs/Kernel"
        },
        {
            "type": "path",
            "url": "../../libs/Cli"
        },
        {
            "type": "path",
            "url": "../../libs/McpServer"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "bash ../../bin/serve.sh 8103"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
