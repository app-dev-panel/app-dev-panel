{
    "name": "app-dev-panel/spiral-playground",
    "type": "project",
    "description": "Spiral playground app demonstrating ADP integration",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "app-dev-panel/adapter-cycle": "*",
        "app-dev-panel/adapter-spiral": "*",
        "cycle/database": "^2.0",
        "monolog/monolog": "^3.5",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "spiral/boot": "^3.14",
        "spiral/core": "^3.14",
        "spiral/http": "^3.14",
        "spiral/router": "^3.14",
        "symfony/var-dumper": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../libs/Adapter/Cycle"
        },
        {
            "type": "path",
            "url": "../../libs/Adapter/Spiral"
        },
        {
            "type": "path",
            "url": "../../libs/API"
        },
        {
            "type": "path",
            "url": "../../libs/Kernel"
        },
        {
            "type": "path",
            "url": "../../libs/Cli"
        },
        {
            "type": "path",
            "url": "../../libs/McpServer"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "bash ../../bin/serve.sh 8105"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
