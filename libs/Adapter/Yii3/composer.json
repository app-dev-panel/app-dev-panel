{
    "name": "app-dev-panel/adapter-yii3",
    "type": "library",
    "description": "Yii 3 framework adapter for ADP — auto-wires debug collectors, proxies, and inspector into Yii 3 applications",
    "keywords": [
        "debug",
        "debug-panel",
        "debugger",
        "debugbar",
        "profiler",
        "yii",
        "yii3",
        "yiisoft",
        "yii-debug",
        "inspector",
        "monitoring",
        "observability",
        "tracing",
        "logging",
        "performance",
        "apm",
        "ai",
        "llm",
        "developer-tools",
        "devtools",
        "app-dev-panel",
        "adp",
        "application-development-panel",
        "development-server"
    ],
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "app-dev-panel/api": "*",
        "app-dev-panel/kernel": "*",
        "app-dev-panel/cli": "*",
        "app-dev-panel/frontend-assets": "*",
        "guzzlehttp/guzzle": "^7.5",
        "guzzlehttp/psr7": "^2.4",
        "jetbrains/phpstorm-attributes": "^1.0",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0|^2.0",
        "psr/log": "^1.0|^2.0|^3.0",
        "symfony/var-dumper": "^6.4|^7.0|^8.0",
        "yiisoft/aliases": "^3.0",
        "yiisoft/arrays": "^2.0|^3.0",
        "yiisoft/config": "^1.3",
        "yiisoft/di": "^1.0",
        "yiisoft/files": "^2.0",
        "yiisoft/json": "^1.0",
        "yiisoft/profiler": "^3.0",
        "yiisoft/proxy": "^1.2",
        "yiisoft/strings": "^2.2",
        "yiisoft/var-dumper": "^1.7"
    },
    "require-dev": {
        "ext-curl": "*",
        "ext-sockets": "*",
        "maglnet/composer-require-checker": "^4.2",
        "nyholm/psr7": "^1.3",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^1.2",
        "roave/infection-static-analysis-plugin": "^1.16",
        "spatie/phpunit-watcher": "^1.23",
        "vimeo/psalm": "^5.26",
        "yiisoft/error-handler": "^3.0",
        "yiisoft/event-dispatcher": "^1.0",
        "yiisoft/log": "^2.0",
        "yiisoft/yii-console": "^2.0",
        "yiisoft/yii-http": "^1.0"
    },
    "suggest": {
        "yiisoft/rbac": "Required for role/permission hierarchy in the Authorization inspector",
        "yiisoft/user": "Required to show current identity and guest state in the Authorization inspector",
        "yiisoft/auth": "Required to list configured authentication methods (guards) in the Authorization inspector",
        "yiisoft/access": "Required to list the active access checker in the Authorization inspector"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../Kernel"
        },
        {
            "type": "path",
            "url": "../../API"
        },
        {
            "type": "path",
            "url": "../../Cli"
        },
        {
            "type": "path",
            "url": "../../FrontendAssets"
        }
    ],
    "autoload": {
        "psr-4": {
            "AppDevPanel\\Adapter\\Yii3\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppDevPanel\\Adapter\\Yii3\\Tests\\": "tests"
        }
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": "params.php",
            "bootstrap": "bootstrap.php",
            "di": "di.php",
            "di-console": "di-console.php",
            "di-web": [
                "di-web.php",
                "di-api.php"
            ],
            "di-providers": "di-providers.php",
            "events-web": "events-web.php",
            "events-console": "events-console.php"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "composer/package-versions-deprecated": true,
            "yiisoft/config": false
        }
    },
    "scripts": {
        "test": "phpunit --testdox --no-interaction",
        "test-watch": "phpunit-watcher watch"
    }
}
