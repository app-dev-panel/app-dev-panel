{
    "name": "app-dev-panel/adapter-yii2",
    "type": "yii2-extension",
    "description": "Yii 2 framework adapter for Application Development Panel (ADP)",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "app-dev-panel/api": "*",
        "app-dev-panel/kernel": "*",
        "app-dev-panel/cli": "*",
        "guzzlehttp/guzzle": "^7.5",
        "guzzlehttp/psr7": "^2.4",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.0",
        "psr/container": "^2.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0|^2.0",
        "psr/log": "^3.0",
        "yiisoft/yii2": "^2.0.50"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "yiisoft/yii2-debug": "^2.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../Kernel"
        },
        {
            "type": "path",
            "url": "../../API"
        },
        {
            "type": "path",
            "url": "../../Cli"
        }
    ],
    "autoload": {
        "psr-4": {
            "AppDevPanel\\Adapter\\Yii2\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppDevPanel\\Adapter\\Yii2\\Tests\\": "tests"
        }
    },
    "extra": {
        "bootstrap": "AppDevPanel\\Adapter\\Yii2\\Bootstrap"
    },
    "config": {
        "sort-packages": true
    }
}
