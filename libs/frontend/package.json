{
  "name": "root",
  "private": true,
  "homepage": "https://github.com/app-dev-panel/app-dev-panel",
  "keywords": [
    "debug",
    "gen-code",
    "app-dev-panel"
  ],
  "author": "Dmitrii Derepko <xepozzd@gmail.com> (https://github.com/xepozz)",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/app-dev-panel/app-dev-panel"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@mui/icons-material": "^7.0.0",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.0.0",
    "@mui/x-data-grid": "^7.0.0",
    "@mui/x-tree-view": "^7.1.1",
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^22.12.0",
    "@vitejs/plugin-react": "^4.2.1",
    "gh-pages": "^6.1.1",
    "lerna": "^8.1.8",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.4.4",
    "verdaccio": "^5.30.3",
    "vite": "^5.4.1",
    "vite-plugin-svgr": "^5.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "scripts": {
    "predeploy": "VITE_ENV=github npm run build; npm run copy-toolbar",
    "deploy": "VITE_ENV=github gh-pages -t true -d packages/panel/dist",
    "start": "lerna run start --parallel --verbose",
    "build": "lerna run build --parallel --verbose",
    "build:dev": "npm run build:dev -w packages/panel; npm run build -w packages/toolbar; npm run copy-toolbar",
    "serve:dev": "npm run serve:dev -w packages/panel",
    "copy-toolbar": "mkdir packages/panel/dist/toolbar && cp -r packages/toolbar/dist/bundle.* packages/toolbar/dist/assets packages/panel/dist/toolbar",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"packages/*/src/**/*.{ts,tsx}\"",
    "check": "npm run format:check && npm run lint",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.browser.config.ts"
  },
  "overrides": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "@vitest/browser": "^2.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.11",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.0.0",
    "vitest": "^2.1.9",
    "webdriverio": "^9.15.0"
  }
}
