{
  "name": "@app-dev-panel/panel",
  "version": "0.0.2",
  "main": "src/index.tsx",
  "homepage": ".",
  "keywords": [
    "debug",
    "gen-code",
    "app-dev-panel"
  ],
  "author": "Dmitrii Derepko <xepozzd@gmail.com> (https://github.com/xepozz)",
  "license": "BSD-3-Clause",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/app-dev-panel/app-dev-panel",
    "directory": "packages/panel"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "start": "vite",
    "build": "npm run build:prod",
    "build:dev": "tsc --build tsconfig.build.json && VITE_BUILD_ID=${VITE_BUILD_ID:-`git rev-parse --short HEAD`} VITE_ENV=${VITE_ENV:-dev} vite build",
    "build:prod": "rm -rf dist; tsc --build tsconfig.build.json && VITE_BUILD_ID=${VITE_BUILD_ID:-`git rev-parse --short HEAD`} VITE_ENV=${VITE_ENV:-github} vite build",
    "test": "vite test",
    "serve:dev": "vite preview --host",
    "serve:prod": "VITE_ENV=github vite preview --host",
    "generate-service-worker": "tsc && vite build && yes | cp -rf build/service-worker.js* build/static public",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@app-dev-panel/sdk": "^0.0.2",
    "@app-dev-panel/toolbar": "^0.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.2",
    "redux-state-sync": "^3.1.4",
    "remark-gfm": "^4.0.1",
    "swagger-ui-react": "^5.17.14"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/redux-state-sync": "^3.1.10",
    "@types/swagger-ui-react": "^5.18.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.2.5",
    "prettier-plugin-organize-imports": "^4.0.0",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "web-vitals": "^5.2.0",
    "workbox-background-sync": "^7.0.0",
    "workbox-broadcast-update": "^7.0.0",
    "workbox-cacheable-response": "^7.0.0",
    "workbox-core": "^7.0.0",
    "workbox-expiration": "^7.0.0",
    "workbox-google-analytics": "^7.0.0",
    "workbox-navigation-preload": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-range-requests": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0",
    "workbox-streams": "^7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
