{
  "name": "root",
  "private": true,
  "homepage": "https://github.com/yiisoft/yii-dev-panel",
  "keywords": [
    "yiisoft",
    "yii",
    "debug",
    "gii",
    "yii-dev-panel"
  ],
  "author": "Dmitrii Derepko <xepozzd@gmail.com> (https://github.com/xepozz)",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/yiisoft/yii-dev-panel"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/material-icons": "^5.2.7",
    "@originjs/vite-plugin-federation": "^1.3.5",
    "@types/node": "^22.12.0",
    "@vitejs/plugin-react": "^4.2.1",
    "gh-pages": "^6.1.1",
    "lerna": "^8.1.8",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.4.4",
    "verdaccio": "^5.30.3",
    "vite": "^5.4.1",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "scripts": {
    "predeploy": "VITE_ENV=github npm run build; npm run copy-toolbar",
    "deploy": "VITE_ENV=github gh-pages -t true -d packages/yii-dev-panel/dist",
    "start": "lerna run start --parallel --verbose",
    "build": "lerna run build --parallel --verbose",
    "build:dev": "npm run build:dev -w packages/yii-dev-panel; npm run build -w packages/yii-dev-toolbar; npm run copy-toolbar",
    "serve:dev": "npm run serve:dev -w packages/yii-dev-panel",
    "copy-toolbar": "mkdir packages/yii-dev-panel/dist/toolbar && cp -r packages/yii-dev-toolbar/dist/bundle.* packages/yii-dev-toolbar/dist/assets packages/yii-dev-panel/dist/toolbar",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"packages/*/src/**/*.{ts,tsx}\"",
    "check": "npm run format:check && npm run lint",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.browser.config.ts"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "@vitest/browser": "^2.1.9",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.12.11",
    "playwright": "^1.52.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.0.0",
    "vitest": "^2.1.9"
  }
}
